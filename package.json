{
  "name": "diff-hop",
  "displayName": "Diff Hop",
  "description": "Lightweight commit-to-commit diff navigation for VS Code Git diffs.",
  "version": "1.0.0",
  "publisher": "chamod-abeywickrama",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/KCSAbeywickrama/diff-hop.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:diffHop.previousCommit",
    "onCommand:diffHop.nextCommit",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "diffHop.previousCommit",
        "title": "Git: Previous Commit (Diff Hop)",
        "icon": "$(arrow-left)"
      },
      {
        "command": "diffHop.nextCommit",
        "title": "Git: Next Commit (Diff Hop)",
        "icon": "$(arrow-right)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "diffHop.previousCommit",
          "group": "navigation@9",
          "when": "resourceScheme == git && diffHop.active"
        },
        {
          "command": "diffHop.nextCommit",
          "group": "navigation@10",
          "when": "resourceScheme == git && diffHop.active"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^6.0.3"
  }
}
